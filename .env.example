# HealthGuard Central Server Configuration
# Set these in Render dashboard under Environment > Environment Variables

# Database (Render provides this automatically when you add a PostgreSQL instance)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/healthguard_central

# API keys that edge nodes use to authenticate (comma-separated)
# Generate a key: python -c "import secrets; print(secrets.token_hex(32))"
ALLOWED_API_KEYS=dev-test-key

# Server
HOST=0.0.0.0
PORT=10000
